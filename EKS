Persistent Volume (PV)
hostPath Example
apiVersion: v1
kind: PersistentVolume

metadata:
  name: my-pv

spec:
  capacity:
    storage: 5Gi

  accessModes:
    - ReadWriteOnce

  hostPath:
    path: /data/demo
kubectl apply -f pv.yaml
kubectl get pv
--------------------------------------------------------------
Persistent Volume Claim (PVC)
apiVersion: v1
kind: PersistentVolumeClaim

metadata:
  name: my-pvc

spec:
  accessModes:
    - ReadWriteOnce

  resources:
    requests:
      storage: 2Gi
kubectl apply -f pvc.yaml
kubectl get pvc
