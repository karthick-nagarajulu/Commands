  name: nginx-storage

spec:
  replicas: 1

  selector:
    matchLabels:
      app: nginx

  template:
    metadata:
      labels:
        app: nginx

    spec:
      containers:
      - name: nginx
        image: nginx

        volumeMounts:
        - mountPath: "/usr/share/nginx/html"
          name: storage

      volumes:
      - name: storage
        persistentVolumeClaim:
          claimName: my-pvc
